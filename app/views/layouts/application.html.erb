<!-- app/views/layouts/application.html.erb -->
<!DOCTYPE html>
<html>
  <head>
    <title>Rails RPG Game</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <style>
      .rpg-container {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        padding: 20px 0;
      }
      .rpg-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 15px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
      }
      .battle-log {
        background: #1a1a1a;
        color: #00ff00;
        font-family: 'Courier New', monospace;
        border-radius: 8px;
        max-height: 300px;
        overflow-y: auto;
      }
      .hp-bar {
        background: #dc3545;
        border-radius: 10px;
      }
      .exp-bar {
        background: #28a745;
        border-radius: 10px;
      }
      .stat-card {
        background: linear-gradient(45deg, #f093fb 0%, #f5576c 100%);
        color: white;
        border-radius: 10px;
      }
    </style>
  </head>

  <body>
    <div class="rpg-container">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-10">
            <!-- ヘッダー -->
            <div class="text-center mb-4">
              <h1 class="text-white">🗡️ Rails RPG Game ⚔️</h1>
              <!-- current_playerのnilチェックを追加 -->
              <% if current_player.present? %>
                <p class="text-white-50">勇者: <%= current_player.name %> (Lv.<%= current_player.level %>)</p>
              <% else %>
                <p class="text-white-50">冒険者よ、ようこそ！</p>
              <% end %>
            </div>

            <!-- フラッシュメッセージ -->
            <% if notice %>
              <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= notice %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% end %>
            
            <% if alert %>
              <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= alert %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
  </body>
</html>